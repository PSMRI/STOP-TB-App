<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.home.HomeFragment"
        android:label="@string/menu_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_nav_home_to_allBenFragment"
            app:destination="@id/allBenFragment" />
        <action
            android:id="@+id/action_nav_home_to_abhaBenFragment"
            app:destination="@id/abhaBenFragment" />
        <action
            android:id="@+id/action_nav_home_to_ncdFragment"
            app:destination="@id/ncdFragment" />
        <action
            android:id="@+id/action_homeFragment_to_cdFragment"
            app:destination="@id/cdFragment" />
    </fragment>

    <fragment
        android:id="@+id/allBenFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.AllBenFragment"
        android:label="@string/icon_title_ben"
        tools:layout="@layout/fragment_all_ben">
        <action
            android:id="@+id/action_allBenFragment_to_newBenRegFragment"
            app:destination="@id/newBenRegFragment" />
        <action
            android:id="@+id/action_allBenFragment_to_newChildAsBenRegistrationFragment"
            app:destination="@id/newChildAsBenRegistrationFragment" />
        <argument
            android:name="source"
            android:defaultValue="0"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/abhaBenFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.AbhaBenFragment"
        android:label="@string/icon_title_ben"
        tools:layout="@layout/fragment_all_ben">
        <action
            android:id="@+id/action_abhaBenFragment_to_newBenRegFragment"
            app:destination="@id/newBenRegFragment" />
        <argument
            android:name="source"
            android:defaultValue="0"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/newBenRegTypeFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.new_ben_registration.NewBenRegTypeFragment"
        android:label="@string/frag_new_ben_reg_type_title"
        tools:layout="@layout/fragment_new_ben_reg_type">
        <argument
            android:name="hhId"
            app:argType="long" />
        <action
            android:id="@+id/action_newBenRegTypeFragment_to_newBenRegG15Fragment"
            app:destination="@id/newBenRegG15Fragment"
            app:popUpTo="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/newBenRegG15Fragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.new_ben_registration.ben_age_more_15.NewBenRegG15Fragment"
        android:label="@string/adult_registration">
        <argument
            android:name="hhId"
            app:argType="long" />
        <argument
            android:name="benId"
            android:defaultValue="0L"
            app:argType="long" />
        <action
            android:id="@+id/action_newBenRegG15Fragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/newBenRegFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.new_ben_registration.ben_form.NewBenRegFragment"
        android:label="NewBenRegFragment">
        <argument
            android:name="hhId"
            app:argType="long" />
        <argument
            android:name="relToHeadId"
            app:argType="integer" />
        <argument
            android:name="benId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="selectedBenId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="gender"
            android:defaultValue="0"
            app:argType="integer" />
        <argument
            android:name="isAddSpouse"
            android:defaultValue="0"
            app:argType="integer" />
        <action
            android:id="@+id/action_newBenRegFragment_self"
            app:destination="@id/newBenRegFragment"
            app:launchSingleTop="true" />
        <action
            android:id="@+id/action_newChild_asBenRegFragment"
            app:destination="@id/newChildAsBenRegistrationFragment"
            app:launchSingleTop="true" />
    </fragment>

    <fragment
        android:id="@+id/newChildAsBenRegistrationFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.all_ben.new_ben_registration.new_child_ben.NewChildAsBenRegistrationFragment"
        android:label="NewChildAsBenRegistrationFragment">
        <argument
            android:name="hhId"
            app:argType="long" />
        <argument
            android:name="relToHeadId"
            app:argType="integer" />
        <argument
            android:name="benId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="selectedBenId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="gender"
            android:defaultValue="0"
            app:argType="integer" />
        <argument
            android:name="isAddSpouse"
            android:defaultValue="0"
            app:argType="integer" />
        <action
            android:id="@+id/action_newBenRegFragment_self"
            app:destination="@id/newBenRegFragment"
            app:launchSingleTop="true" />
    </fragment>

    <fragment
        android:id="@+id/ncdFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.NcdFragment"
        android:label="@string/icon_title_ncd"
        tools:layout="@layout/rv_icon_grid">
        <action
            android:id="@+id/action_ncdFragment_to_ncdEligibleListFragment"
            app:destination="@id/ncdEligibleListFragment" />
        <action
            android:id="@+id/action_ncdFragment_to_ncdListFragment"
            app:destination="@id/ncdListFragment" />
        <action
            android:id="@+id/action_ncdFragment_to_ncdNonEligibleListFragment"
            app:destination="@id/ncdNonEligibleListFragment" />
        <action
            android:id="@+id/action_ncdFragment_to_ncdPriorityListFragment"
            app:destination="@id/ncdPriorityListFragment" />
        <action
            android:id="@+id/action_ncdFragment_to_ncdReferredListFragment"
            app:destination="@id/ncdRefferedList" />
    </fragment>

    <fragment
        android:id="@+id/ncdEligibleListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_eligible_list.NcdEligibleListFragment"
        android:label="@string/ncd_eligible_list"
        tools:layout="@layout/fragment_ncd_eligible_list">
        <action
            android:id="@+id/action_ncdEligibleListFragment_to_cbacFragment"
            app:destination="@id/cbacFragment" />
    </fragment>

    <fragment
        android:id="@+id/ncdListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_list.NcdListFragment"
        android:label="@string/ncd_list"
        tools:layout="@layout/fragment_ncd_list" />

    <fragment
        android:id="@+id/ncdNonEligibleListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_non_eligible_list.NcdNonEligibleListFragment"
        android:label="@string/ncd_non_eligible_list"
        tools:layout="@layout/fragment_ncd_non_eligible_list" />

    <fragment
        android:id="@+id/ncdPriorityListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_priority_list.NcdPriorityListFragment"
        android:label="@string/ncd_priority_list"
        tools:layout="@layout/fragment_ncd_priority_list" />

    <fragment
        android:id="@+id/cbacFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.cbac.CbacFragment"
        android:label="@string/cbac_form">
        <argument
            android:name="benId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="cbacId"
            android:defaultValue="0"
            app:argType="integer" />
        <argument
            android:name="ashaId"
            android:defaultValue="0"
            app:argType="integer" />
        <action
            android:id="@+id/action_cbacFragment_to_ncdReferForm"
            app:destination="@id/NCDReferalForm" />
    </fragment>

    <fragment
        android:id="@+id/NCDReferalForm"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_referred.form.NCDReferalFormFragment"
        android:label="NCDReferalForm">
        <argument
            android:name="benId"
            app:argType="long" />
        <argument
            android:name="referral"
            app:argType="string" />
        <argument
            android:name="referralType"
            app:argType="string" />
        <argument
            android:name="cbacId"
            android:defaultValue="0"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/ncdRefferedList"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_referred.list.NcdRefferedList"
        android:label="NcdRefferedList">
        <action
            android:id="@+id/action_ncdRefferedList_to_NCDReferalFormFragment"
            app:destination="@id/NCDReferalFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/NCDReferalFormFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.ncd_referred.followUp.NCDReferalFormFragment"
        android:label="NCDReferalFormFragment">
        <argument
            android:name="benId"
            app:argType="long" />
        <argument
            android:name="hhId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/cdFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.communicable_diseases.CdFragment"
        android:label="@string/communicable_diseases">
        <action
            android:id="@+id/action_cdFragment_to_TBScreeningListFragment"
            app:destination="@id/TBScreeningListFragment" />
        <action
            android:id="@+id/action_cdFragment_to_TBSuspectedListFragment"
            app:destination="@id/TBSuspectedListFragment" />
        <action
            android:id="@+id/action_cdFragment_to_TBConfirmedListFragment"
            app:destination="@id/TBConfirmedListFragment" />
    </fragment>

    <fragment
        android:id="@+id/TBScreeningListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_screening.list.TBScreeningListFragment"
        android:label="@string/tb_screening_list">
        <action
            android:id="@+id/action_TBScreeningListFragment_to_TBScreeningFormFragment"
            app:destination="@id/TBScreeningFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/TBScreeningFormFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_screening.form.TBScreeningFormFragment"
        android:label="@string/tb_screening_form">
        <argument
            android:name="benId"
            app:argType="long" />
        <action
            android:id="@+id/action_TBScreeningFormFragment_to_ncdReferForm"
            app:destination="@id/NCDReferalForm" />
    </fragment>

    <fragment
        android:id="@+id/TBSuspectedListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_suspected.list.TBSuspectedListFragment"
        android:label="@string/tb_suspected_list">
        <action
            android:id="@+id/action_TBSuspectedListFragment_to_TBSuspectedFragment"
            app:destination="@id/TBSuspectedFragment" />
    </fragment>

    <fragment
        android:id="@+id/TBSuspectedFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_suspected.form.TBSuspectedFragment"
        android:label="@string/tb_suspected_form">
        <argument
            android:name="benId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/TBConfirmedListFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_confirmed.list.TBConfirmedListFragment"
        android:label="@string/tb_confirmed_list">
        <action
            android:id="@+id/action_TBConfirmedListFragment_to_TBConfirmedFormFragment"
            app:destination="@id/TBConfirmedFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/TBConfirmedFormFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.non_communicable_diseases.tb_confirmed.from.TBConfirmedFormFragment"
        android:label="@string/tb_confirmed_form">
        <argument
            android:name="benId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.dashboard.DashboardFragment"
        android:label="@string/dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/syncDashboardFragment"
        android:name="org.piramalswasthya.stoptb.ui.home_activity.sync_dashboard.SyncDashboardFragment"
        android:label="@string/sync_dashboard"
        tools:layout="@layout/fragment_sync_dashboard" />

</navigation>