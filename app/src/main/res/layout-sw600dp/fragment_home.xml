<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.home_activity.home.HomeFragment">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_theme_light_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/ll_full_load_progress"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/ll_quick_refresh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/bg_dashboard_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_normal"
                android:paddingTop="@dimen/padding_small"
                android:paddingEnd="@dimen/padding_small"
                android:paddingBottom="@dimen/padding_small"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_quick_refresh_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/roboto_medium"
                    android:text="@string/quick_refresh_not_updated"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_quick_refresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_quick_refresh_button"
                    android:fontFamily="@font/roboto_bold"
                    android:gravity="center"
                    android:minHeight="@dimen/_28sdp"
                    android:minWidth="@dimen/_74sdp"
                    android:paddingHorizontal="@dimen/padding_normal"
                    android:text="@string/quick_refresh_action"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

            </LinearLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tl_home_viewpager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/bg_tab_strip"
                android:padding="8dp"
                app:tabGravity="fill"
                app:tabIndicator="@drawable/bg_tab_indicator"
                app:tabIndicatorFullWidth="false"
                app:tabIndicatorHeight="0dp"
                app:tabInlineLabel="true"
                app:tabMaxWidth="0dp"
                app:tabMode="fixed"
                app:tabPaddingBottom="16dp"
                app:tabPaddingEnd="24dp"
                app:tabPaddingStart="24dp"
                app:tabPaddingTop="16dp"
                app:tabRippleColor="@color/md_theme_light_primaryContainer"
                app:tabSelectedTextColor="@color/md_theme_light_primary"
                app:tabTextAppearance="@style/TextAppearance.Sakhi.HomeTab"
                app:tabTextColor="@color/md_theme_light_onSurfaceVariant" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp2_home"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_full_load_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tv_load_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/padding_small"
                android:text="@string/home_fragment_percent_download_text"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/md_theme_light_onSurfaceVariant"
                tools:visibility="visible" />

            <ProgressBar
                android:id="@+id/pb_load_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
