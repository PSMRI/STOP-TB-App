<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="ben"
            type="org.piramalswasthya.stoptb.model.BenBasicDomain" />

        <variable
            name="clickListener"
            type="org.piramalswasthya.stoptb.adapters.BenListAdapter.BenClickListener" />

        <variable
            name="showAbha"
            type="Boolean" />

        <variable
            name="showSyncIcon"
            type="Boolean" />

        <variable
            name="hasAbha"
            type="Boolean" />

        <variable
            name="showRegistrationDate"
            type="Boolean" />
        <variable
            name="father"
            type="Boolean" />
        <variable
            name="husband"
            type="Boolean" />
        <variable
            name="spouse"
            type="Boolean"/>

        <variable
            name="role"
            type="Integer" />
        <variable
            name="isMatched"
            type="Boolean" />
        <variable
            name="showActionButtons"
            type="Boolean" />


    </data>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_normal"
        android:elevation="@dimen/padding_normal"
        app:cardCornerRadius="@dimen/padding_normal"
        app:cardElevation="@dimen/padding_normal">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:paddingTop="@dimen/padding_tiny"
            android:paddingBottom="0dp"
            android:onClick="@{() -> clickListener.onClickedBen(ben)}">

                <androidx.cardview.widget.CardView
                    android:id="@+id/ll_title_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/padding_normal"
                    android:layout_marginTop="@dimen/margin_normal"
                    android:background="?attr/colorOnPrimary"
                    android:paddingHorizontal="@dimen/padding_tiny"
                    app:cardCornerRadius="@dimen/padding_normal"
                    app:layout_constraintTop_toTopOf="parent">
                    <LinearLayout
                        android:id="@+id/ll_title_bar_ll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_hh_logo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:paddingVertical="@dimen/padding_normal"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="?attr/colorPrimary" />

                        <TextView
                            android:id="@+id/tv_hh_id"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:drawablePadding="@dimen/padding_small"
                            android:gravity="center_vertical"
                            android:padding="@dimen/padding_small"
                            android:text="@{ben.benFullName}"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:layout_marginEnd="@dimen/padding_small"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorPrimaryVariant"
                            app:drawableTint="?attr/colorPrimary"
                            tools:text="Hello Meister" />

                        <Button
                            android:id="@+id/btn_new_ben"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/margin_small"
                            android:drawableStart="@drawable/ic_person"
                            android:onClick="@{()-> clickListener.onClickedHouseHold(ben)}"
                            android:paddingHorizontal="@dimen/padding_tiny"
                            android:text="@string/btn_rv_item_hh_add_ben"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:visibility="gone"
                            app:cornerRadius="@dimen/padding_small"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_hh_id" />
                        <TextView
                            android:id="@+id/head"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hof"
                            android:visibility="gone"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorPrimaryVariant"
                            app:drawableTint="?attr/colorPrimary"
                            android:layout_gravity="center_vertical|end"
                            android:textStyle="bold"/>

                        <ImageView
                            android:id="@+id/iv_isHead"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone"
                            app:tint="?attr/colorPrimary"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginHorizontal="@dimen/padding_small"
                            android:src="@drawable/ic__hh" />

                        <ImageView
                            android:id="@+id/iv_isDeath"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginHorizontal="@dimen/padding_small"
                            android:visibility="@{ben.isDeath == true ? View.VISIBLE : View.GONE}"
                            android:contentDescription="@string/iv_death_indicator"
                            android:src="@drawable/ic_death" />

                        <ImageView
                            android:id="@+id/iv_call"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:padding="4dp"
                            android:visibility="gone"
                            android:src="@drawable/ic_call_icon"
                            android:layout_gravity="center"
                            android:onClick="@{()->clickListener.onClickedForCall(ben)}"
                            android:background="?selectableItemBackgroundBorderless"
                            android:layout_marginEnd="4dp" />

                        <ImageView
                            android:id="@+id/ivSoftDelete"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_delete"
                            android:layout_gravity="center_vertical|end"
                            android:contentDescription="@string/str_duplicate_record"
                            android:layout_marginHorizontal="@dimen/padding_small"
                            android:onClick="@{()->clickListener.onClickSoftDeleteBen(ben)}" />

                        <ImageView
                            android:id="@+id/iv_sync_state"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginHorizontal="@dimen/padding_small"
                            android:contentDescription="@string/iv_sync_state_tv"
                            app:syncState="@{ben.syncState}"
                            tools:src="@drawable/ic_synced" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/ll_ben_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="@dimen/padding_normal"
                    android:layout_marginTop="@dimen/margin_normal"
                    app:layout_constraintTop_toBottomOf="@+id/ll_title_bar">

                        <LinearLayout
                            android:id="@+id/ncd_husband_name"
                            showLayout="@{husband}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tv_husband_name_ph"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.spouseName}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="Dummy" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ncd_father_name"
                            showLayout="@{father}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tv_father_name_ph"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.fatherName}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="Dummy" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ncd_spouse_name"
                            showLayout="@{spouse}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tv_spouse_name_ph"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.spouseName}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="Dummy" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/age_ben"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.age}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="45 Years" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/gender"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.gender}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="Female" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/HOF"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                           <ImageView
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:src="@drawable/ic_icon_head_of_family" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/hof"
                                android:textStyle="bold"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary" />
                        </LinearLayout>

                    </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_ben_details_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:layout_marginHorizontal="@dimen/padding_normal"
                    app:layout_constraintTop_toBottomOf="@+id/ll_ben_details">

                        <LinearLayout
                            android:id="@+id/registration_date"
                            showLayout="@{showRegistrationDate}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/registration_date"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.regDate}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="12-12-4523" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/beneficiary_id"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                benIdText="@{ben.benId}"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="Lala Land" />
                        </LinearLayout>

                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:id="@+id/mob"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mobile_number"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.mobileNo}"
                                android:layout_below="@+id/mob"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="0123456789" />
                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@{ben.isConsent ? @drawable/verified : @drawable/not_verified}"
                                android:layout_toRightOf="@+id/mob"
                                android:layout_marginStart="5dp"
                                android:visibility="gone" />
                        </RelativeLayout>

                    </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_ben_details_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="@dimen/padding_normal"
                    app:layout_constraintTop_toBottomOf="@id/ll_ben_details_2">

                        <LinearLayout
                            android:id="@+id/ll_vital_action"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_vital_screen"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@android:color/holo_green_dark"
                                android:onClick="@{()-> showActionButtons ? clickListener.onClickVitalScreen(ben) : clickListener.onClickResult(ben)}"
                                android:text="@string/vital_screen"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                android:visibility="gone"
                                app:cornerRadius="@dimen/padding_normal"
                                app:strokeColor="?attr/colorPrimary"
                                app:strokeWidth="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:visibility="@{ben.isDeath ? View.VISIBLE : View.GONE}"
                            android:padding="@dimen/padding_small">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/date_of_death"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.dateOfDeath}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/blank_space"
                            showLayout="@{showAbha? !hasAbha : showAbha}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small"/>

                        <LinearLayout
                            showLayout="@{showAbha? !hasAbha : showAbha}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_abha"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_small"
                                android:backgroundTint="@android:color/holo_green_dark"
                                android:onClick="@{()-> clickListener.onClickABHA(ben)}"
                                android:text="@string/abha"
                                android:visibility="@{ben.isDeath == true ? View.INVISIBLE : View.VISIBLE}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                app:cornerRadius="@dimen/padding_normal"
                                app:strokeColor="?attr/colorPrimary" />
                        </LinearLayout>

                        <LinearLayout
                            showLayout="@{showAbha? hasAbha: showAbha}"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_small">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/abha_number"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                    android:textColor="?attr/colorOnPrimary" />

                                <ImageView
                                    android:id="@+id/tvIsNewAbha"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_5sdp"
                                    android:src='@{ben.isNewAbha ? @drawable/ic_new_abha : @drawable/ic_existing_abha}' />

                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@{ben.abhaId}"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="?attr/colorOnPrimary"
                                tools:text="0123456789"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvTitleDuplicaterecord"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:layout_gravity="center_vertical"
                            android:textColor="@color/md_theme_light_onTertiary"
                            android:fontFamily="@font/roboto_bold"
                            android:textSize="@dimen/_12sdp"
                            android:visibility="gone"
                            android:text="@string/str_duplicate_record" />
                    </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_ben_details_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal"
                android:layout_marginHorizontal="@dimen/padding_normal"
                android:layout_marginBottom="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/ll_ben_details_3">

                        <Button
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:id="@+id/btn_above_30"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:onClick="@{()-> clickListener.clickedAddAllBenBtn(ben,isMatched,false)}"
                            android:text="@string/add_eye_surgery"
                            tools:ignore="NestedWeights"/>

                    </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_add_spouse_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="gone"
                android:orientation="horizontal"
                android:layout_marginHorizontal="@dimen/padding_normal"
                app:layout_constraintTop_toBottomOf="@id/ll_ben_details_4">
                
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_children"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/add_children"
                            android:visibility="gone"
                            android:layout_marginEnd="5dp"
                            android:backgroundTint="@android:color/holo_green_dark"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorOnPrimary"
                            app:cornerRadius="@dimen/padding_small"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="1dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_spouse"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:visibility="gone"
                            android:text="@string/add_wife"
                            android:backgroundTint="@android:color/holo_green_dark"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorOnPrimary"
                            app:cornerRadius="@dimen/padding_small"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="1dp"/>
                </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>
