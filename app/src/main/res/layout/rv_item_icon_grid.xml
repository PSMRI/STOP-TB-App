<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="homeIcon"
            type="org.piramalswasthya.stoptb.model.Icon" />

        <variable
            name="clickListener"
            type="org.piramalswasthya.stoptb.adapters.IconGridAdapter.GridIconClickListener" />

        <variable
            name="scope"
            type="kotlinx.coroutines.CoroutineScope" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_icon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:onClick="@{()-> clickListener.onClicked(homeIcon)}"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeColor="@{homeIcon.colorPrimary ? 0xFFD9F1EB : 0xFFFFE0CC}"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="154dp"
            android:background="@{homeIcon.colorPrimary ? @drawable/bg_home_card_soft_teal : @drawable/bg_home_card_soft_orange}"
            android:orientation="vertical"
            android:padding="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <FrameLayout
                    android:id="@+id/icon_circle"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@{homeIcon.colorPrimary ? @drawable/bg_dashboard_icon_teal : @drawable/bg_dashboard_icon_orange}">

                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_icon_grid_icon"
                        android:scaleType="centerInside"
                        app:imageResource="@{homeIcon.icon}"
                        app:tint="@android:color/white"
                        tools:src="@drawable/ic__ben" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_count"
                    scope="@{scope}"
                    recordCount="@{homeIcon.count}"
                    visibleOrGone="@{homeIcon.count != null}"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_dashboard_badge"
                    android:gravity="center"
                    android:textColor="#394544"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="6" />
            </RelativeLayout>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:labelFor="@id/imageView2"
                android:maxLines="2"
                android:text="@{homeIcon.title}"
                android:textColor="#223233"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="All Beneficiaries" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:text="@{homeIcon.subtitle}"
                android:textColor="#5A6A6A"
                android:textSize="12sp"
                visibleOrGone="@{homeIcon.subtitle != null}"
                tools:text="View and manage all beneficiaries" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_details"
                    android:textColor="#FF7A28"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FF7A28" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
