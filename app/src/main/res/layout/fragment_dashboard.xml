<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ui.home_activity.dashboard.DashboardFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Filters Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Time Period Filter -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTimePeriod"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/filter_time_period">

                <AutoCompleteTextView
                    android:id="@+id/actvTimePeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="@string/filter_today"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Village Filter -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilVillage"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="@string/filter_village">

                <AutoCompleteTextView
                    android:id="@+id/actvVillage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="@string/filter_all_villages"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Card 1: Total TB Screenings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFF9C4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_tb_screenings"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037" />

                <TextView
                    android:id="@+id/tvTbScreeningTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#4E342E"
                    android:layout_marginTop="4dp"
                    tools:text="45" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvTbScreeningMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Male: 20" />

                    <TextView
                        android:id="@+id/tvTbScreeningFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Female: 15" />

                    <TextView
                        android:id="@+id/tvTbScreeningChildren"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.3"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Children(&lt;15y): 5" />

                    <TextView
                        android:id="@+id/tvTbScreeningOthers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        android:gravity="end"
                        tools:text="Others: 5" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2: Total TB Suspected -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFF9C4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_tb_suspected"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037" />

                <TextView
                    android:id="@+id/tvTbSuspectedTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#4E342E"
                    android:layout_marginTop="4dp"
                    tools:text="12" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvTbSuspectedMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Male: 6" />

                    <TextView
                        android:id="@+id/tvTbSuspectedFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Female: 4" />

                    <TextView
                        android:id="@+id/tvTbSuspectedChildren"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.3"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Children(&lt;15y): 1" />

                    <TextView
                        android:id="@+id/tvTbSuspectedOthers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        android:gravity="end"
                        tools:text="Others: 1" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3: Total TB Confirmed -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFF9C4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_tb_confirmed"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037" />

                <TextView
                    android:id="@+id/tvTbConfirmedTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#4E342E"
                    android:layout_marginTop="4dp"
                    tools:text="3" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvTbConfirmedMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Male: 2" />

                    <TextView
                        android:id="@+id/tvTbConfirmedFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Female: 1" />

                    <TextView
                        android:id="@+id/tvTbConfirmedChildren"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.3"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        tools:text="Children(&lt;15y): 0" />

                    <TextView
                        android:id="@+id/tvTbConfirmedOthers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#5D4037"
                        android:gravity="end"
                        tools:text="Others: 0" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row: NIKSHAY IDs + ABHA IDs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Card 4: NIKSHAY IDs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFF9C4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nikshay_ids"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037" />

                    <TextView
                        android:id="@+id/tvNikshayCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#4E342E"
                        android:layout_marginTop="4dp"
                        tools:text="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 5: ABHA IDs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFF9C4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/abha_ids"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037" />

                    <TextView
                        android:id="@+id/tvAbhaCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#4E342E"
                        android:layout_marginTop="4dp"
                        tools:text="25" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
