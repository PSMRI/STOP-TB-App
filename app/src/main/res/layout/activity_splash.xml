<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_stop_tb_splash"
    tools:context=".ui.splash.SplashActivity">

    <View
        android:id="@+id/topGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-70dp"
        android:alpha="0.35"
        android:background="@drawable/bg_stop_tb_splash_glow" />

    <View
        android:id="@+id/bottomGlow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-110dp"
        android:layout_marginBottom="-90dp"
        android:alpha="0.25"
        android:background="@drawable/bg_stop_tb_splash_glow" />

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <FrameLayout
            android:id="@+id/splashLogoContainer"
            android:layout_width="158dp"
            android:layout_height="158dp"
            android:background="@drawable/bg_stop_tb_splash_logo"
            android:elevation="10dp">

            <ImageView
                android:id="@+id/splashLogo"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_native_name"
                android:src="@mipmap/ic_launcher_foreground" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:letterSpacing="0.05"
            android:text="@string/splash_stop_tb"
            android:textColor="@android:color/white"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/splash_tagline"
            android:textColor="#D7FFFA"
            android:textSize="16sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/dotContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/splashDotOne"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="7dp"
                android:background="@drawable/bg_stop_tb_splash_dot" />

            <View
                android:id="@+id/splashDotTwo"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="7dp"
                android:background="@drawable/bg_stop_tb_splash_dot" />

            <View
                android:id="@+id/splashDotThree"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="7dp"
                android:background="@drawable/bg_stop_tb_splash_dot" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
