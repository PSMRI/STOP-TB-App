<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_theme_light_background">

        <LinearLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="156dp"
            android:background="@drawable/bg_camp_connect_header"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/ib_back"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/camp_back"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/md_theme_light_onPrimary" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/opensans_semibold"
                    android:text="@string/camp_connect_title"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/md_theme_light_onPrimary"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/camp_connect_subtitle"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="#E6FFFC" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_connect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="22dp"
            app:cardBackgroundColor="@color/sakhi_card_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:strokeColor="@color/sakhi_outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_camp_status_offline"
                    android:fontFamily="@font/opensans_semibold"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="@string/camp_hub_not_connected"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textColor="@android:color/holo_red_dark"
                    android:textStyle="bold"
                    tools:text="Camp Hub Not Connected" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_camp_qr_panel"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/opensans_semibold"
                        android:gravity="center"
                        android:text="@string/camp_scan_qr_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/md_theme_light_onSurface" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/camp_scan_qr_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/md_theme_light_onSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_scan"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_camp_scan_button"
                        android:text="@string/camp_hub_scan"
                        android:textAllCaps="false"
                        android:textColor="@color/md_theme_light_onPrimary"
                        android:textStyle="bold"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_qr_code"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconTint="@color/md_theme_light_onPrimary" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/opensans_semibold"
                    android:text="@string/camp_manual_url_title"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textColor="@color/md_theme_light_onSurface" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_camp_hub_url"
                    style="@style/Widget.Sakhi.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/camp_hub_url_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_camp_hub_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        tools:text="http://192.168.137.1:8080/" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_connect"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/camp_hub_connect"
                    android:textAllCaps="false"
                    android:textColor="@color/md_theme_light_primary"
                    android:textStyle="bold"
                    app:cornerRadius="18dp"
                    app:strokeColor="@color/md_theme_light_primary"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/pb_connect"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
