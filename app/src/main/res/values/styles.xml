<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="radio_item_lang" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
<!--        <item name="android:buttonTint">?attr/colorPrimary</item>-->
    </style>


    <style name="rv_item_ben_fields">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">@dimen/margin_narrow</item>
    </style>

    <style name="nav_header_item_tv">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">@dimen/padding_small</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.TitleMedium</item>
        <item name="android:gravity">center_vertical</item>
    </style>


    <style name="WindowAnimationTransition">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="cbac_rl_risk_assessment">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">@dimen/padding_normal</item>
    </style>

    <style name="cbac_tv_hint_risk_assessment">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_alignParentStart">true</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.TitleSmall</item>
    </style>

    <style name="cbac_ed_hint">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyMedium</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="cbac_ed_rg">
        <item name="android:paddingStart">@dimen/padding_normal</item>
        <item name="android:paddingEnd">@dimen/padding_normal</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="cbac_ed_rb">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyMedium</item>
    </style>

    <style name="cbac_ed_asterisk">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@android:color/holo_green_light</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:paddingRight">5dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
    </style>

    <style name="Theme.Sakhi.ActionBar" parent="Theme.Material3.Dark">
        <item name="colorSurface">@color/sakhi_toolbar_surface</item>
    </style>

    <style name="Theme.Custom.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@drawable/bg_toolbar_surface</item>
        <item name="android:textColor">@color/md_theme_light_onPrimary</item>
        <item name="titleTextColor">@color/md_theme_light_onPrimary</item>
        <item name="subtitleTextColor">@color/md_theme_light_onPrimary</item>
        <item name="popupTheme">@style/ThemeOverlay.Material3.Light</item>
        <item name="android:minHeight">76dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Sakhi.MaterialCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/sakhi_surface_soft</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/sakhi_outline_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Sakhi.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/md_theme_light_onPrimary</item>
        <item name="backgroundTint">@color/md_theme_light_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.Sakhi.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/sakhi_surface_soft</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/sakhi_outline_soft</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="boxStrokeErrorColor">@color/md_theme_light_error</item>
    </style>

    <style name="Widget.Sakhi.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@color/sakhi_surface_soft</item>
        <item name="itemBackground">@drawable/bg_nav_drawer_item</item>
        <item name="itemTextColor">@color/nav_item_tint</item>
        <item name="itemIconTint">@color/nav_item_tint</item>
        <item name="itemShapeInsetStart">8dp</item>
        <item name="itemShapeInsetEnd">8dp</item>
        <item name="itemShapeInsetTop">4dp</item>
        <item name="itemShapeInsetBottom">4dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Sakhi.Fab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/md_theme_light_primary</item>
        <item name="tint">@color/md_theme_light_onPrimary</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.Sakhi.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/md_theme_light_primary</item>
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>
    </style>

    <style name="Widget.Sakhi.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/md_theme_light_primary</item>
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
    </style>

   <style name="AppBottomSheetDialogTheme"
        parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppModalStyle</item>
    </style>

    <style name="CustomSwitchStyle" parent="ThemeOverlay.AppCompat">
        <item name="colorControlActivated">#4CAF50</item> <!-- ON color -->
        <item name="colorSwitchThumbNormal">#B0BEC5</item> <!-- OFF thumb -->
        <item name="android:colorForeground">#CFD8DC</item> <!-- Track OFF -->
    </style>
    <style name="AppModalStyle"
        parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/rounded_dialog</item>
    </style>

    <style name="SCBSwitch" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#46bdbf</item>
        <item name="colorSwitchThumbNormal">#f1f1f1</item>
        <item name="android:colorForeground">#42221f1f</item>
    </style>

    <style name="PinWidget.PinView" parent="Widget.AppCompat.EditText">
        <item name="android:background">@null</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:textCursorDrawable">@drawable/pv_invisible_image</item>
        <item name="android:textSelectHandle">@drawable/pv_invisible_image</item>
        <item name="android:textSelectHandleLeft">@drawable/pv_invisible_image</item>
        <item name="android:textSelectHandleRight">@drawable/pv_invisible_image</item>
    </style>

</resources>
